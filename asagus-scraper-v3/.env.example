ENVIRONMENT=local
FRONTEND_ORIGIN=http://localhost:3000

POSTGRES_URL=postgresql://asagus:asagus@postgres:5432/asagus
REDIS_URL=redis://redis:6379/0
OPENSEARCH_HOST=http://opensearch:9200
QDRANT_HOST=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=asagus-graph

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=asagus-access
MINIO_SECRET_KEY=change-this-minio-secret
MINIO_BUCKET=asagus-raw-html

LLM_PROVIDER=disabled
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Optional provider-specific keys. The GUI can also store a key for the current backend session.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
DEEPINFRA_API_KEY=
CEREBRAS_API_KEY=
FIREWORKS_API_KEY=
HUGGINGFACE_API_KEY=
PERPLEXITY_API_KEY=

# Third-party Claude/OpenAI-compatible gateway example:
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=anthropic/claude-opus-4.6
# LLM_API_KEY=your-gateway-key
# LLM_BASE_URL=https://your-gateway.example.com/v1

# Optional proxy and enrichment providers from the architecture document.
BRIGHTDATA_USERNAME=
BRIGHTDATA_PASSWORD=
WEBSHARE_API_KEY=
IPROYAL_API_KEY=
GOOGLE_GEOCODING_API_KEY=

CRAWL_CONCURRENCY_LIMIT=200
DISCOVERY_CONCURRENCY_LIMIT=20
CPU_WORKER_PROCESSES=4
PIPELINE_QUEUE_MAXSIZE=5000
BROWSER_POOL_SIZE=10
LLM_FALLBACK_CACHE_DAYS=7
MDP_COLD_START_PHASE=A
POLICY_ENGINE_LOG_LEVEL=INFO
ROBOTS_CACHE_TTL_HOURS=24
DOMAIN_TOKEN_BUCKET_CAPACITY=8
DOMAIN_TOKEN_REFILL_PER_SECOND=0.25
SELECTOR_FINGERPRINT_MIN_CONFIDENCE=0.75
LLM_EXTRACTION_MIN_CONFIDENCE=0.50

# Local safety default. Set true only when you want the fetch layer to make network requests.
ENABLE_NETWORK_FETCH=false
ENABLE_SEARCH_DISCOVERY=false
